version: "3.8"

networks:
  servicos:
    external:
      name: servicos

services:
  pgweb:
    container_name: pgweb
    restart: "no"
    image: sosedoff/pgweb:0.14.2
    ports: 
      - "50420:8081"
    networks:
      - servicos
    dns_opt:
      - single-request-reopen
    labels:
      com.centurylinklabs.watchtower.enable: false
