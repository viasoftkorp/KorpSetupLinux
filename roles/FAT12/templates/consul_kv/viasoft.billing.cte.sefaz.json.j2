{
  "Authorization": {
    "Secret": "{{ secret }}"
  },
  "ServiceBus": {
    "StorageConnectionString": "Server={{ postgres_container_name }},5432; Host={{ postgres_container_name }}; Port=5432; Database={{ service_vars.db.name }}; User Id={{ postgres.korp_user }}; Password={{ postgres.korp_password }};"
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server={{ postgres_container_name }},5432; Host={{ postgres_container_name }}; Port=5432; Database={{ service_vars.db.name }}; User Id={{ postgres.korp_user }}; Password={{ postgres.korp_password }};"
  },
  "EnableEnvironmentDependentConnectionString": "false",
  "ACBr": {
    "Enabled": true,
    "ClientId": "{{ services_secrets.Others.ACBr.ClientId }}",
    "ClientSecret": "{{ services_secrets.Others.ACBr.ClientSecret }}",
    "AuthTokenUrl": "https://auth.acbr.api.br/realms/ACBrAPI/protocol/openid-connect/token",
    "BaseUrl": "https://prod.acbr.api.br/",
    "TimeoutSeconds": 60
  }
}
